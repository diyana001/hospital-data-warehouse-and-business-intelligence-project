  <Kpis>
    <Kpi dwd:design-time-name="e3297504-d2eb-4e9b-a53b-689f435888d8">
      <ID>KPI</ID>
      <Name>Revenue KPI</Name>
      <AssociatedMeasureGroupID>Fact Billing</AssociatedMeasureGroupID>
      <Value>[Measures].[Amount]</Value>
      <Goal>3000000</Goal>
      <Status>Case 
When KPIValue("Revenue KPI") / KPIGoal("Revenue KPI") &gt;= 1 Then 1
When KPIValue("Revenue KPI") / KPIGoal("Revenue KPI") &gt;= 0.8 Then 0
Else -1
End</Status>
      <TrendGraphic>Standard Arrow</TrendGraphic>
      <StatusGraphic>Traffic Light</StatusGraphic>
    </Kpi>
    <Kpi dwd:design-time-name="fe04eb2d-baf2-4311-bc1f-28ec6fc97356">
      <ID>KPI 1</ID>
      <Name>Doctor Service Volume KPI</Name>
      <AssociatedMeasureGroupID>Fact Billing</AssociatedMeasureGroupID>
      <Value>[Measures].[Fact Billing Count]</Value>
      <Goal>500</Goal>
      <Status>Case 
When KPIValue("Doctor Service Volume KPI") / KPIGoal("Doctor Service Volume KPI") &gt;= 1 Then 1
When KPIValue("Doctor Service Volume KPI") / KPIGoal("Doctor Service Volume KPI") &gt;= 0.8 Then 0
Else -1
End</Status>
      <TrendGraphic>Standard Arrow</TrendGraphic>
      <StatusGraphic>Shapes</StatusGraphic>
    </Kpi>
  </Kpis>
